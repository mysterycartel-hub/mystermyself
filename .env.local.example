# ============================================================
# MysterMyself Ecosystem OS — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://mysterymyself.com

# ── Supabase ─────────────────────────────────────────────────
# Get these from: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-only, never expose to client

# ── Stripe ───────────────────────────────────────────────────
# Get these from: dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                   # From Stripe webhook dashboard

# ── Stripe Price IDs ─────────────────────────────────────────
# Create products in Stripe Dashboard, then paste the price IDs here
STRIPE_PRICE_GOLD_PLAYBOOK=price_...
STRIPE_PRICE_TCU_MEMBERSHIP=price_...
STRIPE_PRICE_COURIER_STARTER=price_...
STRIPE_PRICE_FOOD_POPUP=price_...
STRIPE_PRICE_FANTASY_DRAFT_BIBLE=price_...
STRIPE_PRICE_AI_OPERATOR=price_...
